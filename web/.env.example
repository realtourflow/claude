# Copy to .env and fill in. Do not commit .env.

# Postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/realtourflow?schema=public"

# Auth0 (server-side: API JWT validation)
AUTH0_DOMAIN=""
AUTH0_AUDIENCE=""

# Auth0 database connection for password resets (defaults in code to
# "Username-Password-Authentication" when unset).
AUTH0_DB_CONNECTION=""

# Auth0 Management API M2M app (scopes: read:users, update:users; audience
# https://{AUTH0_DOMAIN}/api/v2/). Powers email-verification state + resend.
AUTH0_MGMT_CLIENT_ID=""
AUTH0_MGMT_CLIENT_SECRET=""

# Frontend (NEXT_PUBLIC_*)
NEXT_PUBLIC_AUTH0_DOMAIN=""
NEXT_PUBLIC_AUTH0_CLIENT_ID=""
NEXT_PUBLIC_AUTH0_AUDIENCE=""

# File storage — Vercel Blob (private store). Set a read/write token for local dev,
# or connect a Blob store (the store id + OIDC works automatically on Vercel).
BLOB_READ_WRITE_TOKEN=""
BLOB_STORE_ID=""
# HMAC secret signing the short-lived upload/download capability URLs
# (/api/storage/blob-put, /api/storage/blob-get). A dedicated secret — never
# the store id or R/W token. Has a dev fallback in code; REQUIRED (32+ random
# chars) in Vercel production or the app refuses to serve. Generate with:
#   openssl rand -hex 32
BLOB_CAP_SECRET=""

# Field-level encryption key (lib/crypto.ts) — AES-256-GCM envelope encryption
# for at-rest secrets, today the per-agent SimplyRETS MLS credentials
# (users.mls_key / mls_secret). A 32-byte key as 64 hex chars or base64.
# REQUIRED in Vercel production+preview BEFORE deploy: without it a new MLS
# connect (which encrypts before storing) fails. Empty is fine for local dev/CI
# (tests inject a fixed key). Generate with:
#   openssl rand -hex 32
FIELD_ENCRYPTION_KEY=""

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# DocuSign
DOCUSIGN_INTEGRATION_KEY=""
DOCUSIGN_USER_ID=""
DOCUSIGN_ACCOUNT_ID=""
DOCUSIGN_PRIVATE_KEY=""
DOCUSIGN_BASE_URL=""
# Public URL DocuSign POSTs envelope events to (e.g.
# https://app.realtourflow.com/api/docusign/webhook). Empty = envelopes are
# created without an eventNotification.
DOCUSIGN_WEBHOOK_URL=""
# HMAC key from DocuSign Admin -> Connect. REQUIRED in Vercel production, and
# effectively required wherever DOCUSIGN_WEBHOOK_URL is set — without it the
# webhook rejects every POST with 401 (fail closed, #176). Empty is fine for
# local dev/CI where the webhook isn't live.
DOCUSIGN_CONNECT_HMAC_KEY=""
# Board-keyed template registry (JSON). Template IDs + tab labels come from the
# DocuSign account, so demo and prod each get their own value — Go-Live is an
# ID swap, never a code change. Shape per form:
#   "<form_key>": { "templateId": "...", "label": "...", "board": "BIRMINGHAM_AAR"|""(universal),
#                   "roleMapping": { "<participantRole>": "<TemplateRoleName>" },
#                   "purpose": ""|"baa",
#                   "fieldMap": { "<factOrTermKey>": { "label": "<TabLabel>", "type": "text"|"checkbox", "role": "<TemplateRoleName>"? } } }
# Example (placeholder IDs/labels — replace with the authored templates):
# DOCUSIGN_TEMPLATES='{"buyer_agency_agreement":{"templateId":"<demo-uuid>","label":"Buyer Agency Agreement","purpose":"baa","roleMapping":{"buyer":"Buyer","agent":"Agent"}},"birmingham_general_financed":{"templateId":"<demo-uuid>","label":"General/Financed Residential Contract","board":"BIRMINGHAM_AAR","roleMapping":{"buyer":"Buyer","seller":"Seller","agent":"Agent"},"fieldMap":{"purchase_price":{"label":"PurchasePrice","type":"text"},"earnest_money_amount":{"label":"EarnestMoney","type":"text"},"closing_date":{"label":"ClosingDate","type":"text"},"inspection_days":{"label":"InspectionDays","type":"text"},"home_warranty":{"label":"HomeWarranty","type":"checkbox"}}},"baldwin_residential_purchase":{"templateId":"<demo-uuid>","label":"Residential Purchase Agreement","board":"BALDWIN_GULF_COAST","roleMapping":{"buyer":"Buyer","seller":"Seller","agent":"Agent"},"fieldMap":{"purchase_price":{"label":"PurchasePrice","type":"text"},"flood_zone":{"label":"FloodZone","type":"checkbox"}}}}'
DOCUSIGN_TEMPLATES=""

# ARIVE
ARIVE_API_URL=""
ARIVE_API_KEY=""
ARIVE_CLIENT_ID=""
ARIVE_CLIENT_SECRET=""
ARIVE_WEBHOOK_URL=""
# Shared secret the ARIVE webhook (/api/arive/webhook) requires, sent as an
# `x-arive-token` header or `?token=` query param. Empty = endpoint disabled
# (503); wrong/missing token = 401. Fail-closed, same as INDEXNOW_WEBHOOK_SECRET.
ARIVE_WEBHOOK_SECRET=""

# Google Calendar OAuth
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URL="http://localhost:3000/api/integrations/google-calendar/callback"

# Microsoft Graph OAuth
MICROSOFT_OAUTH_CLIENT_ID=""
MICROSOFT_OAUTH_CLIENT_SECRET=""
MICROSOFT_OAUTH_REDIRECT_URL="http://localhost:3000/api/integrations/microsoft-calendar/callback"
MICROSOFT_OAUTH_TENANT="common"

# HMAC key for the signed CSRF state cookie used by the calendar OAuth connect
# flows. Has a dev default in code; set a strong random value in production.
OAUTH_STATE_SECRET=""

# Resend email (waitlist signups also sync to Resend Contacts when this is set)
RESEND_API_KEY=""

# SimplyRETS (test creds)
SIMPLYRETS_TEST_USER=""
SIMPLYRETS_TEST_PASS=""

# AI field-mapping for the agent form-upload pipeline (lib/form-ai).
# Empty key disables the mapper (uploaded forms land all-fields-need-review).
# Model is swappable; defaults to claude-opus-4-8 when unset.
ANTHROPIC_API_KEY=""
FORM_AI_MODEL=""

# Notion-powered marketing blog (lib/notion.ts -> /blog on realtourflow.com).
# NOTION_TOKEN = an internal-integration secret shared with the "Blog Posts"
# database; NOTION_BLOG_DATABASE_ID = that database's id. Both empty disables
# the blog (the /blog routes render an empty "no posts yet" state).
NOTION_TOKEN=""
NOTION_BLOG_DATABASE_ID=""

# Shared secret gating /api/invites/role (the email->role lookup the Auth0
# Post-Login Action calls to resolve a signing-in user's role). Without it the
# route is an unauthenticated oracle for enumerating accounts/invites. The Auth0
# Action must send this value in the `x-invite-role-token` header. Empty
# disables the route (503); a wrong/missing token returns 401 (fail closed).
INVITE_ROLE_SECRET=""
