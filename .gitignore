# Env
.env
*.env.local

# TypeScript build cache
*.tsbuildinfo

# Claude Code memory
memory/

# OS
.DS_Store
Thumbs.db

# macOS Finder / iCloud duplicate files (e.g. "page 2.tsx", "package-lock 2.json")
# created by sync/copy operations. Never want these in the repo.
* 2.*
* 2
* 3.*
* 3

# Secrets / keys — never commit private keys or certificate material.
# The app reads DOCUSIGN_PRIVATE_KEY from env, not from a file in the tree.
*.pem
ds-private.pem

# One-off DocuSign debug scripts (local scratch; not part of the app).
/web/ds-*.mjs
