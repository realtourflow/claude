          "valueFrom": "arn:aws:secretsmanager:us-east-1:508859666048:secret:realtourflow/database-url-DvT938"
        },
        {
          "name": "AUTH0_DOMAIN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:508859666048:secret:realtourflow/auth0-domain-hHsuRD"
        },
        {
