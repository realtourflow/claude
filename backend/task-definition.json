{
  "family": "realtourflow-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::508859666048:role/realtourflow-task-execution-role",
  "taskRoleArn": "arn:aws:iam::508859666048:role/realtourflow-task-execution-role",
  "containerDefinitions": [
    {
      "name": "realtourflow-api",
      "image": "508859666048.dkr.ecr.us-east-1.amazonaws.com/realtourflow-api:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "secrets": [
        {
