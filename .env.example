PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/realtourflow?sslmode=disable
ALLOWED_ORIGINS=http://localhost:5173
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://api.realtourflow.com

# ARIVE integration (Mountain Mortgage loan milestones)
# API URL — obtain from ARIVE API settings page
ARIVE_API_URL=
# API Key (X-API-KEY header) — from ARIVE Settings > API Integration
ARIVE_API_KEY=
# Bearer token — from ARIVE Settings > API Integration (same page as API Key)
ARIVE_API_TOKEN=
# Full URL of this server's webhook endpoint (e.g. https://api.realtourflow.com/api/arive/webhook)
ARIVE_WEBHOOK_URL=
